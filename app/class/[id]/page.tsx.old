"use client";

import Link from "next/link";
import { useParams, useRouter } from "next/navigation";
import { useEffect, useMemo, useState } from "react";
import { getSupabaseBrowser } from "@/lib/supabaseBrowser";

type ClassRow = {
  id: string;
  name: string;
  created_at: string;
};

type Doc = {
  id: string;
  title: string;
  created_at: string;
};

export default function ClassPage() {
  const { id } = useParams<{ id: string }>();
  const router = useRouter();
  const supabase = useMemo(() => getSupabaseBrowser(), []);

  const [cls, setCls] = useState<ClassRow | null>(null);
  const [docs, setDocs] = useState<Doc[]>([]);
  const [loading, setLoading] = useState(true);
  const [deleting, setDeleting] = useState(false);

  // -------------------------
  // Fetch Class + Documents
  // -------------------------
  useEffect(() => {
    let alive = true;

    (async () => {
      setLoading(true);

      const [{ data: c }, { data: d }] = await Promise.all([
        supabase
          .from("classes")
          .select("id,name,created_at")
          .eq("id", id)
          .maybeSingle(),

        supabase
          .from("documents")
          .select("id,title,created_at")
          .eq("class_id", id)
          .order("created_at", { ascending: false }),
      ]);

      if (!alive) return;

      setCls((c as ClassRow) || null);
      setDocs((d as Doc[]) || []);
      setLoading(false);
    })();

    return () => {
      alive = false;
    };
  }, [id, supabase]);

  // -------------------------
  // Delete Class
  // -------------------------
const deleteClass = async () => {
  const confirmed = confirm(
    "This will permanently delete this class and ALL documents + concepts. Continue?"
  );
  if (!confirmed) return;

  setDeleting(true);

  const { data } = await supabase.auth.getSession();
  const token = data.session?.access_token;

  if (!token) {
    alert("Not logged in.");
    setDeleting(false);
    return;
  }

  const res = await fetch(
    `${process.env.NEXT_PUBLIC_API_URL}/classes/${id}`,
    {
      method: "DELETE",
      headers: {
        Authorization: `Bearer ${token}`,
      },
    }
  );

  setDeleting(false);

  if (!res.ok) {
    alert("Failed to delete class.");
    return;
  }

  router.replace("/library");
};

  // -------------------------
  // UI
  // -------------------------

  if (loading) {
    return (
      <div className="max-w-5xl mx-auto px-4 py-8">
        Loading...
      </div>
    );
  }

  return (
    <div className="max-w-5xl mx-auto px-4 py-8 space-y-8">

      {/* Header */}
      <div className="flex items-start justify-between gap-6">
        <div>
          <h1 className="text-2xl font-semibold">
            {cls?.name || "Class"}
          </h1>
          <p className="text-sm text-slate-500">
            All documents and concepts for this class live here.
          </p>
        </div>

        <div className="flex items-center gap-3">

          <Link
            href={`/class/${id}/concept-map`}
            className="text-sm px-3 py-2 rounded-md border border-slate-300 hover:bg-slate-50"
          >
            View Concept Map
          </Link>

          <button
            onClick={deleteClass}
            disabled={deleting}
            className="text-sm px-3 py-2 rounded-md bg-red-600 text-white hover:bg-red-700 disabled:opacity-50"
          >
            {deleting ? "Deleting..." : "Delete Class"}
          </button>
        </div>
      </div>

      {/* Documents Section */}
      <div>
        <h2 className="text-lg font-medium mb-4">Documents</h2>

        {docs.length === 0 ? (
          <div className="text-sm text-slate-500">
            No documents uploaded yet.
          </div>
        ) : (
          <ul className="space-y-3">
            {docs.map((d) => (
              <li
                key={d.id}
                className="rounded-lg border bg-white p-4 flex items-center justify-between hover:shadow-sm transition"
              >
                <div>
                  <div className="font-medium">{d.title}</div>
                  <div className="text-xs text-slate-400">
                    {new Date(d.created_at).toLocaleDateString()}
                  </div>
                </div>

                <Link
                  href={`/doc/${d.id}`}
                  className="text-sm underline"
                >
                  Open
                </Link>
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  );
}